# All keys below are read in internal/config/config.go (getEnv).

# --- Effectively required for a normal local/production boot ---
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>
MAILCHIMP_API_KEY=<MAILCHIMP_API_KEY>
SES_SENDER=

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=kthais
DB_SSLMODE=disable

# --- Redis (OAuth routes use Redis-backed rate limiting) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- HTTP server ---
SERVER_PORT=8080
# Public URL of this API; used for Google OAuth callback redirect
BACKEND_URL=http://localhost:8080

# Comma-separated CORS origins (spaces after commas are trimmed)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Sessions ---
# Base64-encoded 32-byte key: openssl rand -base64 32
SESSION_KEY=<SESSION_KEY>
# true: dev-friendly session cookies. false: production (secure cookies, stricter SameSite) — see cmd/api/main.go
DEVELOPMENT=true

# --- JWT (RSA PEM; e.g. openssl genrsa -out private.pem 2048; openssl rsa -in private.pem -pubout -out public.pem) ---
JWTSigningKey=<PRIVATE_KEY>
JWTValidatingKey=<PUBLIC_KEY>

# --- Mailchimp ---
MAILCHIMP_USER=<MAILCHIMP_USER>
MAILCHIMP_LIST_ID=<MAILCHIMP_LIST_ID>

# --- Amazon SES ---
# Region passed into the AWS SDK for SES
SES_REGION=eu-north-1
SES_REPLY_TO=contact@kthais.com
# Not read by config.go; the AWS SDK uses the default credential chain, e.g.:
AWS_ACCESS_KEY_ID=<ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<SECRET_ACCESS_KEY>

# --- Cloudflare R2 (S3-compatible) ---
R2_Bucket=
R2_Access_Key_Id=
R2_Secret_Access_Key=
R2_Endpoint=
R2_Account_Id=
